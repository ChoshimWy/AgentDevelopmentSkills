{
  "$id": "https://agent-workflow.local/schemas/release-qualification-handoff-v2.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "candidate_package_lock_hash": {"pattern": "^[0-9a-f]{64}$", "type": "string"},
    "conformance_evidence_fingerprint": {"pattern": "^[0-9a-f]{64}$", "type": "string"},
    "files": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "path": {"minLength": 1, "type": "string"},
          "sha256": {"pattern": "^[0-9a-f]{64}$", "type": "string"},
          "size": {"minimum": 1, "type": "integer"}
        },
        "required": ["path", "sha256", "size"],
        "type": "object"
      },
      "minItems": 8,
      "type": "array"
    },
    "fingerprint": {"pattern": "^[0-9a-f]{64}$", "type": "string"},
    "preflight_blockers": {
      "items": {
        "enum": [
          "release.conformance",
          "release.independent-review",
          "release.license-notice",
          "release.python-distribution"
        ]
      },
      "minItems": 3,
      "type": "array"
    },
    "preflight_gate_fingerprint": {"pattern": "^[0-9a-f]{64}$", "type": "string"},
    "python_compatibility_evidence_fingerprint": {"pattern": "^[0-9a-f]{64}$", "type": "string"},
    "release_identity_sha256": {"pattern": "^[0-9a-f]{64}$", "type": "string"},
    "release_manifest_sha256": {"pattern": "^[0-9a-f]{64}$", "type": "string"},
    "review_key_id": {"pattern": "^[0-9a-f]{64}$", "type": "string"},
    "review_payload_sha256": {"pattern": "^[0-9a-f]{64}$", "type": "string"},
    "schema_version": {"const": "2.0"},
    "source_qualification_fingerprint": {"pattern": "^[0-9a-f]{64}$", "type": "string"},
    "source_revision": {"pattern": "^[0-9a-f]{40}$", "type": "string"},
    "status": {"const": "awaiting-external-signature"}
  },
  "required": [
    "schema_version",
    "status",
    "source_revision",
    "release_identity_sha256",
    "release_manifest_sha256",
    "candidate_package_lock_hash",
    "conformance_evidence_fingerprint",
    "source_qualification_fingerprint",
    "python_compatibility_evidence_fingerprint",
    "review_key_id",
    "review_payload_sha256",
    "preflight_gate_fingerprint",
    "preflight_blockers",
    "files",
    "fingerprint"
  ],
  "title": "Release Qualification Handoff v2",
  "type": "object"
}
