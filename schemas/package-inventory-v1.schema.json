{
  "$defs": {
    "capability": {
      "additionalProperties": false,
      "properties": {
        "binding_permission_profile": {
          "type": [
            "string",
            "null"
          ]
        },
        "id": {
          "minLength": 1,
          "type": "string"
        },
        "permission_profile": {
          "type": [
            "string",
            "null"
          ]
        },
        "version": {
          "minLength": 1,
          "type": "string"
        }
      },
      "required": [
        "id",
        "version",
        "permission_profile",
        "binding_permission_profile"
      ],
      "type": "object"
    },
    "file": {
      "additionalProperties": false,
      "properties": {
        "mode": {
          "maximum": 511,
          "minimum": 0,
          "type": "integer"
        },
        "path": {
          "minLength": 1,
          "type": "string"
        },
        "sha256": {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        }
      },
      "required": [
        "path",
        "sha256",
        "mode"
      ],
      "type": "object"
    }
  },
  "$id": "https://agent-workflow.local/schemas/package-inventory-v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "content_sha256": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "packages": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "capabilities": {
            "items": {
              "$ref": "#/$defs/capability"
            },
            "type": "array"
          },
          "content_sha256": {
            "pattern": "^[0-9a-f]{64}$",
            "type": "string"
          },
          "files": {
            "items": {
              "$ref": "#/$defs/file"
            },
            "type": "array"
          },
          "id": {
            "minLength": 1,
            "type": "string"
          },
          "permissions": {
            "additionalProperties": false,
            "properties": {
              "binding_profiles": {
                "additionalProperties": {
                  "type": "string"
                },
                "type": "object"
              },
              "capability_profiles": {
                "additionalProperties": {
                  "type": "string"
                },
                "type": "object"
              },
              "package": {
                "additionalProperties": {
                  "type": "string"
                },
                "type": "object"
              }
            },
            "required": [
              "package",
              "capability_profiles",
              "binding_profiles"
            ],
            "type": "object"
          },
          "roots": {
            "items": {
              "minLength": 1,
              "type": "string"
            },
            "type": "array",
            "uniqueItems": true
          },
          "version": {
            "minLength": 1,
            "type": "string"
          }
        },
        "required": [
          "id",
          "version",
          "roots",
          "files",
          "capabilities",
          "permissions",
          "content_sha256"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "schema_version": {
      "const": "1.0"
    }
  },
  "required": [
    "schema_version",
    "packages",
    "content_sha256"
  ],
  "title": "Current Package Inventory v1",
  "type": "object"
}
