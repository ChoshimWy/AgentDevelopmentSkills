{
  "$id": "https://agent-workflow.local/schemas/workflow-plan-v1.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "bootstrap_required": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "package_compatibility": {"type": "string"},
          "platform": {"type": "string"},
          "provider": {"type": "string"},
          "required_capabilities": {
            "items": {"type": "string"},
            "type": "array",
            "uniqueItems": true
          }
        },
        "required": ["platform", "provider", "package_compatibility", "required_capabilities"],
        "type": "object"
      },
      "type": "array"
    },
    "edges": {
      "items": {
        "properties": {
          "from": {
            "type": "string"
          },
          "to": {
            "type": "string"
          }
        },
        "required": [
          "from",
          "to"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "fingerprint": {
      "type": "string"
    },
    "missing_capabilities": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "nodes": {
      "items": {
        "properties": {
          "capability": {
            "type": "string"
          },
          "id": {
            "type": "string"
          },
          "mandatory": {
            "type": "boolean"
          },
          "max_retries": {
            "type": "integer"
          },
          "status": {
            "type": "string"
          },
          "timeout_seconds": {
            "type": "integer"
          }
        },
        "required": [
          "id",
          "capability",
          "mandatory",
          "status",
          "timeout_seconds",
          "max_retries"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "package_lock_hash": {
      "pattern": "^[0-9a-f]{64}$",
      "type": "string"
    },
    "plan_id": {
      "type": "string"
    },
    "schema_version": {
      "const": "1.0"
    },
    "status": {
      "enum": [
        "ready",
        "degraded",
        "blocked"
      ]
    },
    "workflow": {
      "properties": {
        "checkpoints": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "independent_review": {
          "type": "boolean"
        },
        "roles": {
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "required": [
        "roles",
        "checkpoints",
        "independent_review"
      ],
      "type": "object"
    }
  },
  "required": [
    "schema_version",
    "plan_id",
    "fingerprint",
    "nodes",
    "edges",
    "status"
  ],
  "title": "Workflow Plan v1",
  "type": "object"
}
